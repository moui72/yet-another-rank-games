# Copy to .env for local development. .env is gitignored; never commit real secrets.
# Local values come from `supabase status` after `supabase start`.

# Supabase Auth (client-safe; the publishable/anon key is meant to be public)
PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
PUBLIC_SUPABASE_ANON_KEY="<local anon / publishable key from `supabase status`>"

# Server-only secrets (never exposed to the client)
SUPABASE_SERVICE_ROLE_KEY="<local service_role / secret key from `supabase status`>"

# Direct Postgres connection used by the server data layer (Data API is disabled;
# see infrastructure.md). Local default:
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"
