# Copy to .env for local development. .env is gitignored; never commit real secrets.
# Local values come from `supabase status` after `supabase start`.
# Supabase key model: publishable (client-safe) replaces legacy anon; secret
# (server-only) replaces legacy service_role.

# Supabase Auth (client-safe; the publishable key is meant to be public)
PUBLIC_SUPABASE_URL="http://127.0.0.1:54321"
PUBLIC_SUPABASE_PUBLISHABLE_KEY="<local publishable key (sb_publishable_...) from `supabase status`>"

# Server-only secret key (bypasses RLS). NEVER commit a real one — Supabase
# auto-revokes secret keys detected in public repositories.
SUPABASE_SECRET_KEY="<local secret key (sb_secret_...) from `supabase status`>"

# Direct Postgres connection used by the server data layer (Data API is disabled;
# see infrastructure.md). Local default:
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:54322/postgres"

# BGG XML API bearer token (required since Oct 2025 — register the app at
# https://boardgamegeek.com/using_the_xml_api). Server-only; leave unset until
# provisioned (live import stays blocked, but the pipeline is built/tested on mocks).
BGG_API_TOKEN=""
