{
	"name": "yet-another-rank-games",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "husky && (svelte-kit sync || true)",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"coverage": "vitest run --coverage",
		"lint": "eslint .",
		"test:e2e": "playwright test",
		"coverage:ratchet": "vitest run --coverage && node scripts/coverage-ratchet.mjs",
		"test:integration": "supabase db reset --local >/dev/null 2>&1 && vitest run --config vitest.integration.config.ts",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.12.1",
		"@chromatic-com/storybook": "^5.2.1",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.1",
		"@storybook/addon-a11y": "^10.5.0",
		"@storybook/addon-docs": "^10.5.0",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.5.0",
		"@storybook/sveltekit": "^10.5.0",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^26.1.1",
		"@vitest/browser-playwright": "4.1.10",
		"@vitest/coverage-v8": "^4.1.10",
		"daisyui": "^5.6.17",
		"dotenv": "^17.4.2",
		"eslint": "^10.7.0",
		"eslint-plugin-storybook": "^10.5.0",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"husky": "^9.1.7",
		"playwright": "^1.61.1",
		"storybook": "^10.5.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"svelte-eslint-parser": "^1.8.0",
		"tailwindcss": "^4.3.2",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.63.0",
		"vite": "^8.0.16",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"@supabase/ssr": "^0.12.0",
		"@supabase/supabase-js": "^2.110.2",
		"fast-xml-parser": "^5.9.3",
		"kysely": "^0.29.3",
		"kysely-postgres-js": "^3.0.0",
		"openskill": "^5.0.1",
		"postgres": "^3.4.9",
		"svelte-dnd-action": "^0.9.70",
		"zod": "^4.4.3"
	}
}
